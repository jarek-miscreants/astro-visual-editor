# TVE server environment template.
#
# Copy this to `.env.local` (gitignored) and fill in real values.
# `.env.local` is auto-loaded by the dev script via Node's
# `--env-file-if-exists` flag.
#
# SECRETS DO NOT GO HERE. The GitHub App's client secret and private
# key live ONLY in the Cloudflare Worker (token broker), set via
# `wrangler secret put`. The TVE server never sees them.

# ─── GitHub App identity (public values) ───────────────────────────
#
# Personal-test App (Jarek's account): currently registered under
#   https://github.com/settings/apps/tailwind-visual-editor
# When ownership transfers to Miscreants (or a fresh Miscreants App
# is registered), update these three values + the broker secrets.
# See docs/integration/app-config.md.
#
# Leave all three unset to disable GitHub mode (CLI dev flow).
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_SLUG=

# ─── Token broker URL ──────────────────────────────────────────────
#
# Base URL of the deployed Cloudflare Worker that brokers OAuth code
# exchange and installation token minting. Leave unset until the
# broker is deployed; auth flows surface a clear error in that state.
GITHUB_APP_BROKER_URL=

# ─── Server runtime mode ───────────────────────────────────────────
#
# `cli`     — original CLI dev tool flow (default)
# `desktop` — Electron-shell flow added during local-SaaS migration
TVE_MODE=cli

# ─── Optional overrides ────────────────────────────────────────────
#
# State directory. Defaults to ~/.tve/. Used by tests; rarely set.
# TVE_HOME=
#
# Explicit project path. Equivalent to passing the path as the CLI
# argument. Used by some launcher scripts.
# TVE_PROJECT_PATH=
#
# HTTP port. Defaults to 3011.
# PORT=3011
