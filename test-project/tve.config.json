{
  "defaultMode": "dev",
  "seo": {
    "preferredAdapter": "component",
    "component": {
      "tagName": "SEO",
      "path": "src/components/SEO.astro",
      "insertion": {
        "mode": "layout-slot",
        "layout": "Layout",
        "slot": "head"
      },
      "fields": {
        "title": "title",
        "description": "description",
        "canonical": "canonical",
        "ogTitle": "ogTitle",
        "ogDescription": "ogDescription",
        "ogImage": "image",
        "twitterImage": "twitterImage",
        "noindex": "noindex"
      }
    }
  },
  "contentView": [
    {
      "id": "publishing",
      "label": "Publishing",
      "items": [
        {
          "collection": "blog",
          "label": "Blog posts",
          "description": "Articles, news, and campaign updates",
          "defaultRoot": "src/content"
        },
        {
          "collection": "whitepapers",
          "label": "White papers",
          "description": "Long-form gated resources",
          "defaultRoot": "src/content"
        }
      ]
    },
    {
      "id": "supporting-content",
      "label": "Supporting content",
      "items": [
        {
          "collection": "authors",
          "label": "Authors",
          "description": "Reusable author profiles",
          "defaultRoot": "src/content"
        },
        {
          "collection": "categories",
          "label": "Categories",
          "description": "Editorial taxonomy used across content",
          "defaultRoot": "src/content"
        }
      ]
    }
  ]
}
