---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About">
  <div class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-gray-800">About This Project</h1>
    <p class="mt-4 text-gray-600 leading-relaxed">
      The Tailwind Visual Editor lets you edit Astro pages visually
      while keeping your source code in sync.
    </p>
    <div class="mt-8 bg-blue-50 border border-blue-200 rounded-lg p-4">
      <h2 class="text-lg font-semibold text-blue-800">Features</h2>
      <ul class="mt-2 space-y-1 text-blue-700">
        <li>Visual class editing</li>
        <li>Live preview</li>
        <li>Source file sync</li>
        <li>Element tree navigation</li>
      </ul>
    </div>
  </div>
</Layout>
