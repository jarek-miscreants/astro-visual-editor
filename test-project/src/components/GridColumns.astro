---
type Columns = "1" | "2" | "3";

interface Props {
  title?: string;
  description?: string;
  columns?: Columns;
  class?: string;
}

const {
  title = "Built for marketing teams",
  description = "A reusable feature grid section with safe fields for copy, layout, and optional slot content.",
  columns = "3",
  class: className = "",
} = Astro.props;

const columnsClass: Record<Columns, string> = {
  "1": "md:grid-cols-1",
  "2": "md:grid-cols-2",
  "3": "md:grid-cols-3",
};
---

<section class:list={["rounded-lg border border-slate-800 bg-slate-950 p-6 text-slate-50", className]}>
    <div class="mb-6 max-w-2xl">
      <h2 class="text-3xl font-semibold tracking-tight">{title}</h2>
      <p class="mt-3 text-slate-300">{description}</p>
    </div>

    <div class:list={["grid grid-cols-1 gap-4", columnsClass[columns]]}>
      <div class="rounded border border-slate-800 bg-slate-900 p-4">
        <h3 class="text-xl font-semibold">Fast updates</h3>
        <p class="mt-2 text-sm text-slate-300">Change copy, images, and CTAs without opening source code.</p>
      </div>
    
      <div class="rounded border border-slate-800 bg-slate-900 p-4">
        <h3 class="text-xl font-semibold">Safe components</h3>
        <p class="mt-2 text-sm text-slate-300">Editors work inside approved fields and variants.</p>
      </div>
    
      <div class="rounded border border-slate-800 bg-slate-900 p-4">
        <h3 class="text-xl font-semibold">Real Astro code</h3>
        <p class="mt-2 text-sm text-slate-300">Every change still lands in the actual project source.</p>
      </div>
    
      <slot />
    </div>
  </section>
