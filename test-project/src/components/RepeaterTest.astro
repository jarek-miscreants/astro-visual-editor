---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
const TestingItems = [
  {
    title: "Testing Title",
    body: "Test item",
  },
  {
    title: "This is antorher field",
    body: "Test item 2",
  },
];
---

<div class={className}>
  <p>New RepeaterTest component</p>

  <div class="grid gap-6">
  {TestingItems.map((item) => (
    <article class="flex flex-col gap-3 rounded-lg border border-slate-200 bg-white p-6">
        <div class="flex flex-col gap-2">
          <h3 class="text-xl font-semibold text-slate-950">{item.title}</h3>
          <p class="text-sm leading-6 text-slate-600">{item.body}</p>
        </div>
    </article>
  ))}
</div>
</div>
