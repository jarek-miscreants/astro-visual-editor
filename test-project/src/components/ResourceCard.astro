---
type ResourceType = "blog" | "whitepaper" | "case-study";

interface Props {
  type?: ResourceType;
  title?: string;
  summary?: string;
  image?: string;
  href?: string;
  gated?: boolean;
  class?: string;
}

const {
  type = "whitepaper",
  title = "How marketers can update Astro sites",
  summary = "A practical resource about structured editing, safe components, and publishing workflows.",
  image = "/images/dj-abby-stract.png",
  href = "/blog/hello-world",
  gated = true,
  class: className = "",
} = Astro.props;

const typeLabel = {
  blog: "Blog post",
  whitepaper: "White paper",
  "case-study": "Case study",
}[type];
---

<article class:list={["overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm", className]}>
  {image && <img class="aspect-[16/9] w-full object-cover" src={image} alt="" />}
  <div class="p-5">
    <div class="flex items-center gap-2">
      <span class="text-xs font-semibold uppercase tracking-wide text-blue-600">{typeLabel}</span>
      {gated && <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-600">Gated</span>}
    </div>
    <h3 class="mt-3 text-xl font-semibold text-slate-950">{title}</h3>
    <p class="mt-2 text-sm leading-6 text-slate-600">{summary}</p>
    <a class="mt-4 inline-flex text-sm font-semibold text-blue-600 hover:text-blue-500" href={href}>
      View resource
    </a>
  </div>
</article>
