---
type Variant = "image-right" | "image-left" | "centered";

interface Props {
  eyebrow?: string;
  headline?: string;
  description?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  image?: string;
  imageAlt?: string;
  variant?: Variant;
  class?: string;
}

const {
  eyebrow = "Client editing demo",
  headline = "Astro builds marketers can actually use",
  description = "A structured editing layer for campaign pages, content updates, and SEO work without exposing clients to implementation details.",
  primaryLabel = "Book a demo",
  primaryHref = "/about",
  secondaryLabel = "View resources",
  secondaryHref = "/blog/hello-world",
  image = "/images/zafcon-hero.webp",
  imageAlt = "Abstract hero artwork",
  variant = "image-right",
  class: className = "",
} = Astro.props;

const isCentered = variant === "centered";
const imageFirst = variant === "image-left";
---

<section
  class:list={[
    "overflow-hidden rounded-xl border border-slate-200 bg-white",
    isCentered ? "px-6 py-14 text-center" : "grid gap-8 p-6 md:grid-cols-2 md:items-center",
    className,
  ]}
>
  <div class:list={[imageFirst && !isCentered ? "md:order-2" : ""]}>
    {eyebrow && <p class="text-sm font-semibold uppercase tracking-wide text-blue-600">{eyebrow}</p>}
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 md:text-5xl">{headline}</h1>
    <p class:list={["mt-4 text-lg leading-8 text-slate-600", isCentered ? "mx-auto max-w-2xl" : ""]}>
      {description}
    </p>
    <div class:list={["mt-8 flex flex-wrap gap-3", isCentered ? "justify-center" : ""]}>
      <a class="rounded bg-blue-600 px-5 py-3 text-sm font-semibold text-white hover:bg-blue-500" href={primaryHref}>
        {primaryLabel}
      </a>
      <a class="rounded border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 hover:bg-slate-50" href={secondaryHref}>
        {secondaryLabel}
      </a>
    </div>
  </div>

  {!isCentered && image && (
    <div class:list={["rounded-lg bg-slate-100 p-3", imageFirst ? "md:order-1" : ""]}>
      <img class="aspect-[4/3] w-full rounded object-cover" src={image} alt={imageAlt} />
    </div>
  )}
</section>
