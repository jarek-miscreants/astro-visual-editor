{
  "name": "tve-broker",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker that brokers GitHub App OAuth code exchange and installation token minting for TVE.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit false --outDir dist --declaration false",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240725.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5",
    "wrangler": "^3.85.0"
  }
}
